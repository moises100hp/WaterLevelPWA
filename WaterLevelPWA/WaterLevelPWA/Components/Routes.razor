@using WaterLevelPWA.Client

<Router AppAssembly="typeof(WaterLevelPWA.Components.App).Assembly"
        AdditionalAssemblies="new[] { typeof(WaterLevelPWA.Client.ClientAssemblyMarker).Assembly }">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(WaterLevelPWA.Components.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="typeof(WaterLevelPWA.Components.Layout.MainLayout)">
            <p role="alert">Página não encontrada.</p>
        </LayoutView>
    </NotFound>
</Router>