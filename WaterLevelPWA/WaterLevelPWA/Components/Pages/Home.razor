@page "/"
@namespace WaterLevelPWA.Components.Pages
@rendermode InteractiveServer
@using WaterLevelPWA.DTO;
@using WaterLevelPWA.Service;
@inject IWaterLevelService WaterLevelService
<PageTitle>Monitoramento de Caixa d'Água</PageTitle>


<div class="container mt-4">
    <h3>Status da Caixa d'Água</h3>
    

    @if (reading == null)
    {
        <div class="alert alert-info">Buscando dados do sensor...</div>
    }
    else
    {
        <div class="tank-wrapper">
            <div class="water-tank-container">
                <div class="level-marker min-marker" style="bottom: @(GetPercentage(reading.MinLevel))%">
                    <span>MÍN (@reading.MinLevel L)</span>
                </div>

                <div class="level-marker max-marker" style="bottom: @(GetPercentage(reading.MaxLevel))%">
                    <span>MÁX (@reading.MaxLevel L)</span>
                </div>

                <div class="water-fill" style="height: @(GetFillPercentage())%; background-color: @GetTankColor()">
                    <span class="water-percentage">@reading.CurrentLevel.ToString("F0") L</span>
                </div>
            </div>
        </div>
    }

    <button class="btn btn-primary mt-3" @onclick="LoadData" disabled="@isLoading">
        @if (isLoading)
        {
            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
            <span> Carregando...</span>
        }
        else
        {
            <span>Atualizar Agora</span>
        }
    </button>
</div>

@code {
    private WaterLevelDTO? reading;
    private bool isLoading = false;
    private PeriodicTimer? timer;
    private CancellationTokenSource cts = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();

        _ = RunAutoUpdate();
    }

    private async Task RunAutoUpdate()
    {
        timer = new PeriodicTimer(TimeSpan.FromSeconds(1));

        try
        {
            while (await timer.WaitForNextTickAsync(cts.Token))
            {
                await LoadData();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            reading = await WaterLevelService.GetLevelAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao buscar dados: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetTankColor()
    {
        if (reading == null) return "#007bff";

        if (reading.CurrentLevel <= reading.MinLevel || reading.CurrentLevel >= reading.MaxLevel)
        {
            return "#dc3545";
        }

        return "#007bff";
    }

    private double GetPercentage(double value)
    {
        if (reading == null) return 0;

        var min = reading.MinLevel;
        var max = reading.MaxLevel;

        if (max <= min) return 0;

        var percent = ((value - min) / (max - min)) * 100.0;
        return Math.Clamp(percent, 0, 100);
    }

    private double GetFillPercentage() => GetPercentage(reading?.CurrentLevel ?? 0);
}