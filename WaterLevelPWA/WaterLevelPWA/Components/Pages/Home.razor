@page "/"
@namespace WaterLevelPWA.Components.Pages
@rendermode InteractiveServer
@using WaterLevelPWA.DTO;
@using WaterLevelPWA.Service;
@inject IWaterLevelService WaterLevelService
<PageTitle>Monitoramento de Caixa d'Água</PageTitle>


<div class="container mt-4">
    <h3>Status da Caixa d'Água</h3>
    

    @if (reading == null)
    {
        <div class="alert alert-info">Buscando dados do sensor...</div>
    }
    else
    {
        <div class="tank-wrapper">
            <div class="water-card">
                <div class="card-header">
                    <div class="header-left">
                        <span class="status-dot"></span>
                        <div class="header-labels">
                            <span class="card-label">Nível Reservatório</span>
                            <span class="card-title">Caixa D'água</span>
                        </div>
                    </div>
                    <span class="card-menu">⋯</span>
                </div>

                <div class="card-body">
                    <div class="tank-visual">
                        <div class="tank-shell">
                            <div class="tank-body">
                                <div class="tank-ring ring-1"></div>
                                <div class="tank-ring ring-2"></div>
                                <div class="tank-ring ring-3"></div>
                                <div class="tank-ring ring-4"></div>
                                <div class="tank-ring ring-5"></div>

                                <div class="water-fill" style="height: @(GetFillPercentage())%; background-color: @GetTankColor()">
                                    <span class="water-percentage">@GetDisplayPercentage()%</span>
                                    <span class="water-value">@GetDisplayValue()</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tank-info">
                        <span class="level-status @GetStatusClass()">@GetStatusText()</span>
                    </div>
                </div>
            </div>
        </div>
    }

    <button class="btn btn-primary mt-3" @onclick="LoadData" disabled="@isLoading">
        @if (isLoading)
        {
            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
            <span> Carregando...</span>
        }
        else
        {
            <span>Atualizar Agora</span>
        }
    </button>
</div>

@code {
    private WaterLevelDTO? reading;
    private bool isLoading = false;
    private PeriodicTimer? timer;
    private CancellationTokenSource cts = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();

        _ = RunAutoUpdate();
    }

    private async Task RunAutoUpdate()
    {
        timer = new PeriodicTimer(TimeSpan.FromSeconds(1));

        try
        {
            while (await timer.WaitForNextTickAsync(cts.Token))
            {
                await LoadData();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            reading = await WaterLevelService.GetLevelAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erro ao buscar dados: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetTankColor()
    {
        if (reading == null) return "#0067d8";

        if (reading.CurrentLevel <= reading.MinLevel || reading.CurrentLevel >= reading.MaxLevel)
        {
            return "#dc3545";
        }

        return "#1c73ff";
    }

    private string GetStatusText()
    {
        if (reading == null) return string.Empty;
        return (reading.CurrentLevel <= reading.MinLevel || reading.CurrentLevel >= reading.MaxLevel)
            ? "Alerta"
            : "Normal";
    }

    private string GetStatusClass()
    {
        if (reading == null) return "status-normal";
        return (reading.CurrentLevel <= reading.MinLevel || reading.CurrentLevel >= reading.MaxLevel)
            ? "status-alert"
            : "status-normal";
    }

    private string GetDisplayPercentage() => GetFillPercentage().ToString("F0");

    private string GetDisplayValue()
    {
        if (reading == null) return string.Empty;
        return $"{reading.CurrentLevel:F2} mca";
    }

    private double GetPercentage(double value)
    {
        if (reading == null) return 0;

        var min = reading.MinLevel;
        var max = reading.MaxLevel;

        if (max <= min) return 0;

        var percent = ((value - min) / (max - min)) * 100.0;
        return Math.Clamp(percent, 0, 100);
    }

    private double GetFillPercentage() => GetPercentage(reading?.CurrentLevel ?? 0);
}